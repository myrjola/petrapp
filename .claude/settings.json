{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(make init)",
      "Bash(make build)",
      "Bash(make test)",
      "Bash(make lint)",
      "Bash(make lint-fix)",
      "Bash(make sec)",
      "Bash(make ci)",
      "Bash(make clean)",
      "Bash(make fuzz*)",
      "Bash(go build *)",
      "Bash(go test *)",
      "Bash(go vet *)"
    ],
    "ask": [
      "Bash(make fly-*)",
      "Bash(make * fly-*)",
      "Bash(make secrets-*)",
      "Bash(fly *)",
      "Bash(flyctl *)"
    ],
    "deny": [
      "Bash(fly deploy*)",
      "Bash(flyctl deploy*)"
    ]
  }
}
