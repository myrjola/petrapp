{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(make init)",
      "Bash(make build)",
      "Bash(make test)",
      "Bash(make lint)",
      "Bash(make lint-fix)",
      "Bash(make sec)",
      "Bash(make ci)",
      "Bash(make clean)",
      "Bash(make fuzz*)",
      "Bash(go build *)",
      "Bash(go test *)",
      "Bash(go vet *)",
      "Bash(make fly-wake *)",
      "Bash(make fly-sql-readonly *)",
      "Bash(make fly-logs *)"
    ],
    "ask": [
      "Bash(make fly-backup *)",
      "Bash(make fly-pprof-*)",
      "Bash(make fly-secrets-push *)",
      "Bash(make fly-sql-write *)",
      "Bash(make fly-sqlite3 *)",
      "Bash(make fly-stresstest *)",
      "Bash(make * fly-*)",
      "Bash(make secrets-*)",
      "Bash(fly *)",
      "Bash(flyctl *)"
    ],
    "deny": [
      "Bash(fly deploy*)",
      "Bash(flyctl deploy*)"
    ]
  }
}
