# Template for secrets/<fly-app>.env (e.g. secrets/petra.env, secrets/petra-staging.env).
# Copy to secrets/<app>.env, fill in real values, then:
#   make secrets-encrypt FLY_APP=<app> && rm secrets/<app>.env
# The plaintext *.env is gitignored; only the encrypted *.env.age is committed.
# Format is KEY=value, one per line — consumed by `fly secrets import`.

# Web push (VAPID). Regenerating these breaks every existing push subscription.
PETRAPP_VAPID_PUBLIC=
PETRAPP_VAPID_PRIVATE=
PETRAPP_VAPID_SUBJECT=

# OpenAI API key (re-mintable from the OpenAI dashboard).
OPENAI_API_KEY=

# Tigris / S3 credentials for the Litestream backup bucket.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
BUCKET_NAME=
AWS_ENDPOINT_URL_S3=
AWS_REGION=
